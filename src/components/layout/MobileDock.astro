---
import { profileData } from '../../utils/profile';
---

<nav
  class="fixed bottom-4 left-1/2 z-30 w-[calc(100%-2rem)] -translate-x-1/2 rounded-full bg-surface/95 px-3 py-2 text-sm text-muted backdrop-blur md:hidden"
  aria-label="Mobile navigation"
>
  <ul class="grid grid-cols-3 items-center text-center">
    <li>
      <a href="/" class="block rounded-full px-3 py-2 transition-colors hover:text-accent">首页</a>
    </li>
    <li>
      <a href="/projects" class="block rounded-full px-3 py-2 transition-colors hover:text-accent">项目</a>
    </li>
    <li>
      <a href={profileData.socials.email} class="block rounded-full px-3 py-2 transition-colors hover:text-accent">联系</a>
    </li>
  </ul>
</nav>
